NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=raredx_password
NEO4J_DATABASE=neo4j

RAREDX_PROCESSED_DIR=data/processed
RAREDX_EMBEDDING_MODEL=cambridgeltl/SapBERT-from-PubMedBERT-fulltext
RAREDX_IC_WEIGHT=0.45
RAREDX_EMBEDDING_WEIGHT=0.35
RAREDX_GRAPH_WEIGHT=0.20
RAREDX_DOC2HPO_URL=
RAREDX_ORIGINAL_HPO_MAPPER_URL=
RAREDX_DOC2HPO_TIMEOUT_SECONDS=20

# Optional LLM QC/selection for HPO mapper candidates.
# Use openai for hosted QC, ollama for local fallback, or off to disable.
RAREDX_LLM_PROVIDER=off
OPENAI_API_KEY=
RAREDX_OPENAI_MODEL=gpt-4o-mini
RAREDX_OLLAMA_URL=http://localhost:11434
RAREDX_OLLAMA_CHAT_MODEL=phi4-mini
